# Creonnect Backend Configuration
# This file contains all environment variables needed to run the system.
# Copy to .env and fill in with your actual values.

# ============================================================================
# ENVIRONMENT
# ============================================================================
ENV=development
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ============================================================================
# DATABASE (PostgreSQL)
# ============================================================================
# Standard PostgreSQL connection
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/creonnect

# Database connection pooling configuration
# IMPORTANT: Increased from defaults for better scalability
DB_POOL_SIZE=20              # Was: 10 (base pool size)
DB_MAX_OVERFLOW=30           # Was: 20 (additional overflow connections)
DB_POOL_TIMEOUT=30           # Timeout waiting for connection (seconds)
DB_POOL_RECYCLE=3600         # Recycle connections after 1 hour
DB_COMMAND_TIMEOUT=10        # PostgreSQL command timeout (seconds)

# ============================================================================
# REDIS
# ============================================================================
REDIS_URL=redis://localhost:6379/0

# ============================================================================
# LLM CONFIGURATION
# ============================================================================
# OpenAI Configuration
OPENAI_API_KEY=sk-...                    # Your OpenAI API key
LLM_MODEL_NAME=gpt-4o-mini               # Model to use
# Azure OpenAI (if using Azure instead of direct OpenAI)
# AZURE_OPENAI_ENDPOINT=https://...
# AZURE_OPENAI_API_KEY=...
# AZURE_OPENAI_API_VERSION=2024-10-21
# AZURE_EMBEDDING_DEPLOYMENT=...

# ============================================================================
# GEMINI API (For Reel Vision Analysis)
# ============================================================================
GEMINI_API_KEY=...                       # Your Google Gemini API key (optional)

# ============================================================================
# BRAND & SECURITY
# ============================================================================
BRAND_API_KEY=...                        # API key for brand-protected endpoints
CREONNECT_SESSION_SECRET=...             # Session encryption secret (generate in production)

# ============================================================================
# LOGGING
# ============================================================================
LOG_LEVEL=INFO
LLM_LOG_FINETUNE_DATASET=0               # Set to 1 to log finetune dataset (dev only)

# ============================================================================
# CIRCUIT BREAKER (OpenAI Resilience)
# ============================================================================
# Circuit breaker configuration for graceful degradation
# Automatically opens if OpenAI API fails, reopens after recovery timeout
CIRCUIT_BREAKER_FAILURE_THRESHOLD=5      # Failures before opening circuit
CIRCUIT_BREAKER_RECOVERY_TIMEOUT=60      # Seconds to wait before retry
CIRCUIT_BREAKER_SUCCESS_THRESHOLD=2      # Successes needed to close circuit

# ============================================================================
# RATE LIMITING (Trend Analysis)
# ============================================================================
# Rate limit for trend refresh endpoint
# Current: 1 request per 30 minutes (cost control)
# Can be overridden per user tier
TREND_RATE_LIMIT_REQUESTS=1              # Requests allowed
TREND_RATE_LIMIT_WINDOW=1800             # Window in seconds (1800 = 30 minutes)

# ============================================================================
# CACHING (Trend Results)
# ============================================================================
# Cache configuration for trend analysis results
TREND_CACHE_TTL_SECONDS=86400            # 24 hours
TREND_CACHE_ENABLED=1                    # Set to 0 to disable caching

# ============================================================================
# RQ JOBS (Background Processing)
# ============================================================================
# Job queue configuration
TREND_ANALYSIS_JOB_TIMEOUT=600            # Job timeout in seconds (10 minutes)
TREND_ANALYSIS_RESULT_TTL=86400           # Result time-to-live (24 hours)
TREND_ANALYSIS_RETRIES=2                  # Number of retries on failure
