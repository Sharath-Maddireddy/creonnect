# =============================================================================
# Creonnect Backend — Environment Variables Template
# =============================================================================
# Copy this file to .env and fill in all required values before running.
# NEVER commit the real .env to git.
# =============================================================================

# ---------------------------------------------------------------------------
# App / Environment
# ---------------------------------------------------------------------------
# Set to "production" in prod. Dev/test modes relax some security checks.
ENV=dev

# ---------------------------------------------------------------------------
# API Security
# ---------------------------------------------------------------------------
# Long random secret used for session cookie signing and token derivation.
# Generate with: python -c "import secrets; print(secrets.token_hex(64))"
CREONNECT_SESSION_SECRET=replace_with_a_long_random_secret_for_cookie_signing

# AES-256 encryption key for stored OAuth access tokens (32-byte hex or base64).
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
CREONNECT_TOKEN_ENCRYPTION_KEY=replace_with_a_32_byte_hex_key

# API key that brands must send in the X-API-Key header to access brand endpoints.
BRAND_API_KEY=replace_with_brand_api_key

# ---------------------------------------------------------------------------
# CORS
# ---------------------------------------------------------------------------
# Comma-separated list of allowed origins for the frontend.
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ---------------------------------------------------------------------------
# Database (PostgreSQL + pgvector)
# ---------------------------------------------------------------------------
# Async SQLAlchemy URL. Must use the asyncpg driver.
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/creonnect

# Connection pool tuning (optional — defaults shown)
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800
DB_COMMAND_TIMEOUT=10

# pgvector HNSW index ef_search parameter (optional, default=40)
PGVECTOR_HNSW_EF_SEARCH=40

# ---------------------------------------------------------------------------
# Redis (RQ job queue + caching)
# ---------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0

# ---------------------------------------------------------------------------
# OpenAI (LLM + Embeddings)
# ---------------------------------------------------------------------------
OPENAI_API_KEY=sk-proj-replace_with_your_openai_api_key

# LLM model to use for structured analysis (default: gpt-4o-mini)
LLM_MODEL_NAME=gpt-4o-mini

# ---------------------------------------------------------------------------
# Google Gemini (Vision / Reel Analysis)
# ---------------------------------------------------------------------------
GEMINI_API_KEY=replace_with_your_gemini_api_key
# Gemini model used for vision analysis (default: gemini-2.0-flash)
# GEMINI_MODEL=gemini-2.0-flash

# ---------------------------------------------------------------------------
# Meta / Instagram OAuth
# ---------------------------------------------------------------------------
# Create a Facebook App at https://developers.facebook.com/
INSTAGRAM_APP_ID=your_facebook_app_id_here
INSTAGRAM_APP_SECRET=your_facebook_app_secret_here
INSTAGRAM_REDIRECT_URI=http://localhost:8000/api/auth/instagram/callback

# ---------------------------------------------------------------------------
# RAG Cache (optional)
# ---------------------------------------------------------------------------
# Directory where the RAG embedding cache is stored (default: .rag_cache)
RAG_CACHE_DIR=.rag_cache

# ---------------------------------------------------------------------------
# DEPRECATED — safe to remove once OAuth flow is fully live
# ---------------------------------------------------------------------------
# INSTAGRAM_SESSION_ID=
