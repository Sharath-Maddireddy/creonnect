# Environment Configuration
# Copy this file to .env and fill in the values

# OpenAI API Key (required for LLM explanations)
OPENAI_API_KEY=
LLM_MODEL_NAME=gpt-4o-mini
# Static API key for brand-protected endpoints
# BRAND_API_KEY=

# Environment: dev, staging, production
ENV=dev




# Meta / Instagram OAuth (required for Instagram login)
INSTAGRAM_APP_ID=your_facebook_app_id_here
INSTAGRAM_APP_SECRET=your_facebook_app_secret_here
INSTAGRAM_REDIRECT_URI=http://localhost:8000/api/auth/instagram/callback
CREONNECT_SESSION_SECRET=replace_with_a_long_random_secret_for_cookie_signing
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CREONNECT_BD_ACCESS_TOKEN=your_creonnect_bd_access_token_here
QUEUE_BACKEND=rq
AWS_REGION=ap-south-1
AWS_SQS_ENDPOINT_URL=
AWS_SQS_ACCOUNT_ANALYSIS_QUEUE_URL=
AWS_SQS_EMBEDDING_INGESTION_QUEUE_URL=
AWS_SQS_REEL_ANALYSIS_QUEUE_URL=

# DEPRECATED: replaced by OAuth flow - remove after OAuth is live
# INSTAGRAM_SESSION_ID=

GEMINI_USE_BATCH=false  # Set to true for background/bulk jobs to use Batch API (50% cheaper, 24h SLA)
# Redis
REDIS_PASSWORD=replace_with_strong_random_password
REDIS_URL=redis://:replace_with_strong_random_password@localhost:6379/0

